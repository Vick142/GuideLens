# Backend environment variables

# Azure Computer Vision API
# Get these from your Azure Portal: https://portal.azure.com
# Resource: Computer Vision
# Copy from: Keys and Endpoint section

# Your Azure Computer Vision endpoint
# Format: https://<region>.api.cognitive.microsoft.com/
AZURE_VISION_ENDPOINT=https://YOUR_REGION.api.cognitive.microsoft.com/

# Your Azure Computer Vision API key
AZURE_VISION_KEY=YOUR_API_KEY_HERE

# Backend server port
BACKEND_PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Node environment
NODE_ENV=development
